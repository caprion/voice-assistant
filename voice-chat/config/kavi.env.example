# Kavi voice assistant — central configuration
# Sourced by shell scripts (source/set -a) and loaded by systemd units
# (EnvironmentFile=) and by kavi.py (each key maps to an os.environ.get()
# default already in the code, so this file only needs to override what's
# different on a given machine — e.g. when installing on a second device,
# copy this file and edit paths/ports, nothing else needs to change).

# --- Project locations ---
KAVI_PROJECT_DIR=/home/nidhi/learn/Code/voice-assistant/voice-chat
KAVI_VENV_PYTHON=/home/nidhi/learn/Code/voice-assistant/voice-enforcer/.venv/bin/python3
KAVI_SKILL_PATH=/home/nidhi/learn/brain/skills/kavi-voice-assistant.md

# --- whisper-server (persistent STT, default engine) ---
WHISPER_SERVER_BIN=/home/nidhi/learn/whisper.cpp/build-cuda/bin/whisper-server
WHISPER_MODEL=/home/nidhi/.cache/whisper.cpp/ggml-small.en.bin
WHISPER_SERVER_HOST=127.0.0.1
WHISPER_SERVER_PORT=8090
WHISPER_SERVER_URL=http://127.0.0.1:8090/inference

# --- whisper-cli (subprocess fallback if whisper-server is down) ---
WHISPER_BIN=/home/nidhi/learn/whisper.cpp/build-cuda/bin/whisper-cli

# --- parakeet-cli (accuracy alt STT, --stt parakeet, no server support) ---
PARAKEET_BIN=/home/nidhi/learn/whisper.cpp/build-cuda/bin/parakeet-cli
PARAKEET_MODEL=/home/nidhi/.cache/parakeet/ggml-model.bin

# --- llama-server (persistent LLM, CPU-only, streaming) ---
LLAMA_SERVER_BIN=/home/nidhi/learn/llama.cpp/build-cuda/bin/llama-server
LLAMA_MODEL=/home/nidhi/.cache/llama.cpp/qwen2.5-1.5b-instruct-q4_k_m.gguf
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8081
LLAMA_SERVER_THREADS=3
LLAMA_SERVER_CTX=2048

# --- llama-cli (subprocess fallback if llama-server is down) ---
LLAMA_BIN=/home/nidhi/learn/llama.cpp/build-cuda/bin/llama-cli

# --- piper TTS (opt-in via --tts) ---
PIPER_VOICE_DIR=/home/nidhi/learn/Code/voice-enforcer
PIPER_VOICE=en_US-lessac-medium
